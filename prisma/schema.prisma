generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId   Int       @id @default(autoincrement())
  username String
  email    String    @unique
  sessions Session[]
}

model Player {
  playerId    Int             @id @default(autoincrement())
  playerName  String
  clubForm    Float           @default(0)
  clubRanking Int?
  userId      Int?
  sessions    PlayerSession[]
}

model Session {
  sessionId      Int             @id @default(autoincrement())
  startDate      DateTime
  endDate        DateTime
  userId         Int
  games          Game[]
  playerSessions PlayerSession[]
  user           User            @relation(fields: [userId], references: [userId])
}

model PlayerSession {
  playerId           Int
  sessionId          Int
  totalGamesPlayed   Int       @default(0)
  gamesWon           Int       @default(0)
  averagePoints      Float     @default(0)
  gamesLost          Int       @default(0)
  lastMatchEnd       DateTime?
  lastPlayedAt       DateTime?
  longestWinStreak   Int       @default(0)
  sessionPlayerId    Int       @id @default(autoincrement())
  totalSecondsPlayed Int       @default(0)
  winStreak          Int       @default(0)
  player             Player    @relation(fields: [playerId], references: [playerId])
  session            Session   @relation(fields: [sessionId], references: [sessionId])

  @@unique([playerId, sessionId])
}

model Game {
  gameId          Int     @id @default(autoincrement())
  sessionId       Int
  player1         Int
  player2         Int
  player3         Int
  player4         Int
  scoreHome       Int
  scoreAway       Int
  gameTimeSeconds Float
  session         Session @relation(fields: [sessionId], references: [sessionId])
}
